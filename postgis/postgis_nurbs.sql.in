-----------------------------------------------------------------------
-- NURBS
-----------------------------------------------------------------------
-- Availability: 3.7.0

-- NURBS curve creation
CREATE OR REPLACE FUNCTION ST_MakeNurbsCurve(integer, geometry, float8[], float8[])
    RETURNS geometry AS 'MODULE_PATHNAME', 'ST_MakeNurbsCurve'
    LANGUAGE 'c' IMMUTABLE STRICT PARALLEL SAFE;

CREATE OR REPLACE FUNCTION ST_MakeNurbsCurve(integer, geometry)
    RETURNS geometry AS $$ SELECT ST_MakeNurbsCurve($1, $2, NULL, NULL) $$
    LANGUAGE 'sql' IMMUTABLE STRICT PARALLEL SAFE;

-- NURBS curve properties
CREATE OR REPLACE FUNCTION ST_NurbsCurveDegree(geometry)
    RETURNS integer AS 'MODULE_PATHNAME', 'ST_NurbsCurveDegree'
    LANGUAGE 'c' IMMUTABLE STRICT PARALLEL SAFE;

CREATE OR REPLACE FUNCTION ST_NurbsCurveControlPoints(geometry)
    RETURNS geometry AS 'MODULE_PATHNAME', 'ST_NurbsCurveControlPoints'
    LANGUAGE 'c' IMMUTABLE STRICT PARALLEL SAFE;

-- NURBS to linestring conversion
CREATE OR REPLACE FUNCTION ST_NurbsCurveToLineString(geometry, integer)
    RETURNS geometry AS 'MODULE_PATHNAME', 'ST_NurbsCurveToLineString'
    LANGUAGE 'c' IMMUTABLE STRICT PARALLEL SAFE;

CREATE OR REPLACE FUNCTION ST_NurbsCurveToLineString(geometry)
    RETURNS geometry AS $$ SELECT ST_NurbsCurveToLineString($1, 32) $$
    LANGUAGE 'sql' IMMUTABLE STRICT PARALLEL SAFE;
